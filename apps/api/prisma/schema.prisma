generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 平台级表 ====================

model Tenant {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  contactPhone String?
  status      String   @default("active") // active, suspended, expired
  subscriptionStatus String   @default("trial") // trial, active, grace, suspended
  subscriptionEndAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions   TenantSubscription[]
  featureFlags    TenantFeatureFlag[]
  shops           Shop[]
  users           User[]
  employees       Employee[]
  roles           Role[]
  dictionaries    Dictionary[]
  systemParameters SystemParameter[]
  files           File[]
  auditLogs       AuditLog[]
  appDevices      AppDevice[]
  customers       Customer[]
  vehicles        Vehicle[]
  appointments    Appointment[]
  receptions      Reception[]
  serviceItems    ServiceItem[]
  workOrders      WorkOrder[]
  workOrderItems  WorkOrderItem[]
  inspectionRecords InspectionRecord[]
  dispatchTasks   DispatchTask[]
  parts           Part[]
  suppliers       Supplier[]
  warehouses      Warehouse[]
  stockBalances   StockBalance[]
  stockBills      StockBill[]
  stockBillItems  StockBillItem[]
  stockMovements  StockMovement[]
  settlements     Settlement[]
  payments        Payment[]
  storedValueCards StoredValueCard[]
  storedValueTransactions StoredValueTransaction[]
  packageCards    PackageCard[]
  packageCardItems PackageCardItem[]
  packageCardTransactions PackageCardTransaction[]
  customerWxBindings CustomerWxBinding[]
  reminders         Reminder[]
  paymentRefunds    PaymentRefund[]
  subscriptionOrders SubscriptionOrder[]
  coupons           Coupon[]
  couponClaims      CouponClaim[]

  @@map("tenants")
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String
  description String?
  priceYearly Decimal  @db.Decimal(12, 2)
  priceMonthly Decimal? @db.Decimal(12, 2) // 月付价格（如 null 则 = priceYearly / 12）
  discount3m  Decimal  @default(0.95) @db.Decimal(4, 2) // 3 个月折扣率
  discount6m  Decimal  @default(0.90) @db.Decimal(4, 2) // 6 个月折扣率
  discount12m Decimal  @default(0.80) @db.Decimal(4, 2) // 12 个月（年付）折扣率
  maxShops    Int
  maxEmployees Int
  features    Json?    // 功能列表 JSON
  status      String   @default("active") // active, inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantSubscriptions TenantSubscription[]
  subscriptionOrders SubscriptionOrder[]

  @@map("subscription_plans")
}

model TenantSubscription {
  id          String   @id @default(cuid())
  tenantId    String
  planId      String
  startAt     DateTime
  endAt       DateTime
  status      String   @default("active") // trial, active, expired, cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@index([planId])
  @@map("tenant_subscriptions")
}

model SubscriptionOrder {
  id              String   @id @default(cuid())
  tenantId        String
  orderNo         String   // 订单号（格式 SUB + yyyyMMdd + 4 位序号）
  planId          String
  months          Int      // 购买月数：1, 3, 6, 12
  originalAmount  Decimal  @db.Decimal(12, 2) // 原价（planPrice / 12 * months）
  discountRate    Decimal  @default(1.0) @db.Decimal(4, 2) // 折扣率（0.80 = 8 折）
  amount          Decimal  @db.Decimal(12, 2) // 实付金额（originalAmount * discountRate）
  status          String   @default("pending") // pending, paid, cancelled, refunded
  paymentMethod   String?  // wechat, alipay
  transactionId   String?  // 第三方交易号（支付成功后回填）
  paidAt          DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id])
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("subscription_orders")
}

model FeatureFlag {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())

  tenantFlags TenantFeatureFlag[]

  @@map("feature_flags")
}

model TenantFeatureFlag {
  id            String   @id @default(cuid())
  tenantId      String
  featureFlagId String
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  featureFlag FeatureFlag @relation(fields: [featureFlagId], references: [id])

  @@unique([tenantId, featureFlagId])
  @@index([tenantId])
  @@map("tenant_feature_flags")
}

// ==================== 商户级表 ====================

model Shop {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  address     String?
  phone       String?
  status      String   @default("active") // active, inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  employees Employee[]

  @@index([tenantId])
  @@map("shops")
}

model User {
  id             String    @id @default(cuid())
  tenantId       String?   // null for platform users
  phone          String
  passwordHash   String
  name           String
  avatar         String?
  isPlatform     Boolean   @default(false)
  status         String    @default("active") // active, disabled
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant         Tenant?   @relation(fields: [tenantId], references: [id])
  employee       Employee?
  userRoles      UserRole[]
  refreshTokens  RefreshToken[]
  files          File[]    @relation("UploadedFiles")
  auditLogs      AuditLog[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([phone])
  @@map("users")
}

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Employee {
  id        String   @id @default(cuid())
  userId    String   @unique
  tenantId  String
  shopId    String
  position  String?
  status    String   @default("active") // active, disabled
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])

  @@index([tenantId])
  @@index([shopId])
  @@map("employees")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String?  // null for platform roles
  name        String
  code        String
  description String?
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant?        @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]
  userRoles     UserRole[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  module      String
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// ==================== 通用表 ====================

model Dictionary {
  id        String   @id @default(cuid())
  tenantId  String?
  type      String
  code      String
  name      String
  sort      Int      @default(0)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, type, code])
  @@index([tenantId, type])
  @@map("dictionaries")
}

model SystemParameter {
  id        String   @id @default(cuid())
  tenantId  String?
  group     String
  key       String
  value     String
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, group, key])
  @@index([tenantId])
  @@map("system_parameters")
}

model File {
  id            String   @id @default(cuid())
  tenantId      String
  uploadedBy    String
  originalName  String
  fileName      String
  mimeType      String
  size          Int
  url           String
  source        String?  // 来源端: web, app
  businessType  String?  // 业务对象类型
  businessId    String?  // 业务对象 ID
  createdAt     DateTime @default(now())

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  uploader User   @relation("UploadedFiles", fields: [uploadedBy], references: [id])

  @@index([tenantId])
  @@index([businessType, businessId])
  @@map("files")
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  userId      String?
  action      String
  targetType  String
  targetId    String?
  changes     Json?
  ip          String?
  createdAt   DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

model AppDevice {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  deviceToken String
  platform    String   // android, ios
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@map("app_devices")
}

// ==================== Sprint 1: 客户车辆与接待 ====================

model Customer {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  phone       String
  gender      String?  // male, female
  email       String?
  address     String?
  remark      String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  vehicles    Vehicle[]
  appointments Appointment[]
  receptions  Reception[]
  workOrders  WorkOrder[]
  wxBindings  CustomerWxBinding[]
  reminders   Reminder[]
  couponClaims CouponClaim[]

  @@index([tenantId])
  @@index([tenantId, phone])
  @@map("customers")
}

model Vehicle {
  id          String   @id @default(cuid())
  tenantId    String
  customerId  String
  plateNo     String
  brand       String?
  model       String?
  vin         String?
  engineNo    String?
  color       String?
  mileage     Int?     // 公里数
  firstRegDate DateTime?
  remark      String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  customer    Customer    @relation(fields: [customerId], references: [id])
  appointments Appointment[]
  receptions  Reception[]
  workOrders  WorkOrder[]

  @@index([tenantId])
  @@index([tenantId, plateNo])
  @@index([tenantId, vin])
  @@map("vehicles")
}

model Appointment {
  id          String   @id @default(cuid())
  tenantId    String
  shopId      String
  customerId  String
  vehicleId   String?
  serviceType String   // repair, wash, maintenance, inspection
  appointTime DateTime
  description String?
  status      String   @default("pending") // pending, confirmed, arrived, cancelled, completed
  remark      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  customer    Customer    @relation(fields: [customerId], references: [id])
  vehicle     Vehicle?    @relation(fields: [vehicleId], references: [id])

  @@index([tenantId])
  @@index([tenantId, shopId])
  @@index([tenantId, appointTime])
  @@map("appointments")
}

model Reception {
  id          String   @id @default(cuid())
  tenantId    String
  shopId      String
  customerId  String
  vehicleId   String
  advisorId   String   // 接待顾问
  appointmentId String? // 关联预约
  arriveTime  DateTime @default(now())
  description String?
  status      String   @default("receiving") // receiving, converted, cancelled
  workOrderId String?  // 转换后的工单
  remark      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  customer    Customer    @relation(fields: [customerId], references: [id])
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id])

  @@index([tenantId])
  @@index([tenantId, shopId])
  @@map("receptions")
}

model ServiceItem {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  category    String   // repair, wash, maintenance, accessory, other
  unit        String   @default("次")
  unitPrice   Decimal  @db.Decimal(12, 2)
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  workOrderItems WorkOrderItem[]

  @@index([tenantId])
  @@index([tenantId, category])
  @@map("service_items")
}

model WorkOrder {
  id              String   @id @default(cuid())
  tenantId        String
  shopId          String
  orderNo         String   // 工单号，自动生成
  orderType       String   // repair, wash, quick
  customerId      String
  vehicleId       String
  vehiclePlateNo  String   // 冗余，方便查询
  vehicleMileage  Int?     // 进店里程
  advisorId       String?  // 服务顾问
  description     String?  // 故障描述/服务要求
  status          String   @default("draft") // draft, quoted, confirmed, dispatching, in_progress, completed, settled, cancelled
  totalAmount     Decimal  @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(12, 2)
  payableAmount   Decimal  @default(0) @db.Decimal(12, 2)
  expectDate      DateTime? // 预计交付时间
  remark          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  customer    Customer    @relation(fields: [customerId], references: [id])
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id])
  items       WorkOrderItem[]
  inspections InspectionRecord[]
  dispatchTasks DispatchTask[]

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@index([tenantId, shopId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("work_orders")
}

model WorkOrderItem {
  id            String   @id @default(cuid())
  tenantId      String
  workOrderId   String
  serviceItemId String?
  partId        String?
  itemType      String   // service, part, addon
  name          String
  quantity      Decimal  @default(1) @db.Decimal(10, 2)
  unit          String   @default("次")
  unitPrice     Decimal  @db.Decimal(12, 2)
  amount        Decimal  @db.Decimal(12, 2)
  technicianId  String?  // 技师
  remark        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  workOrder    WorkOrder    @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  serviceItem  ServiceItem? @relation(fields: [serviceItemId], references: [id])
  part         Part?        @relation(fields: [partId], references: [id])

  @@index([tenantId])
  @@index([workOrderId])
  @@index([partId])
  @@map("work_order_items")
}

model InspectionRecord {
  id          String   @id @default(cuid())
  tenantId    String
  workOrderId String
  category    String   // exterior, interior, engine, chassis, tire, fluid
  item        String
  condition   String   // good, fair, poor, replace
  note        String?
  photoUrl    String?
  createdAt   DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([workOrderId])
  @@map("inspection_records")
}

model DispatchTask {
  id          String   @id @default(cuid())
  tenantId    String
  workOrderId String
  technicianId String
  itemIds     String?  // JSON array of work_order_item ids
  status      String   @default("pending") // pending, in_progress, paused, completed
  startAt     DateTime?
  endAt       DateTime?
  workPlace   String?  // 施工工位
  team        String?  // 班组
  assistantIds String? // 辅修人 ID 列表 (逗号分隔)
  remark      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([workOrderId])
  @@index([technicianId])
  @@map("dispatch_tasks")
}

// ==================== Sprint 2: 库存管理 ====================

model Part {
  id            String   @id @default(cuid())
  tenantId      String
  code          String   // 配件编码
  name          String
  category      String?
  brand         String?
  supplierId    String?  // 供货商
  warrantyMonths Int     @default(0) // 质保月数，0=无质保
  unit          String   @default("个")
  costPrice     Decimal  @default(0) @db.Decimal(12, 2)
  salePrice     Decimal  @default(0) @db.Decimal(12, 2)
  minStock      Int      @default(0) // 库存预警下限
  remark        String?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  supplier    Supplier?   @relation(fields: [supplierId], references: [id])
  stockBalances StockBalance[]
  stockBillItems StockBillItem[]
  stockMovements StockMovement[]
  workOrderItems WorkOrderItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("parts")
}

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  contactName String?
  phone       String?
  address     String?
  remark      String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  parts       Part[]
  stockBills  StockBill[]

  @@index([tenantId])
  @@map("suppliers")
}

model Warehouse {
  id          String   @id @default(cuid())
  tenantId    String
  shopId      String
  name        String
  isDefault   Boolean  @default(false)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  stockBalances StockBalance[]
  stockMovements StockMovement[]

  @@index([tenantId])
  @@index([tenantId, shopId])
  @@map("warehouses")
}

model StockBalance {
  id            String   @id @default(cuid())
  tenantId      String
  warehouseId   String
  partId        String
  quantity      Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt     DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  part      Part      @relation(fields: [partId], references: [id])

  @@unique([tenantId, warehouseId, partId])
  @@index([tenantId])
  @@map("stock_balances")
}

model StockBill {
  id          String   @id @default(cuid())
  tenantId    String
  shopId      String
  billNo      String
  billType    String   // in, out, adjust, return
  supplierId  String?
  relatedType String?  // work_order, etc
  relatedId   String?
  status      String   @default("draft") // draft, confirmed, cancelled
  remark      String?
  operatorId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  supplier    Supplier?   @relation(fields: [supplierId], references: [id])
  items       StockBillItem[]
  movements   StockMovement[]

  @@unique([tenantId, billNo])
  @@index([tenantId])
  @@index([tenantId, billType])
  @@map("stock_bills")
}

model StockBillItem {
  id          String   @id @default(cuid())
  tenantId    String
  billId      String
  partId      String
  quantity    Decimal  @db.Decimal(12, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(12, 2)
  remark      String?
  createdAt   DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  bill        StockBill   @relation(fields: [billId], references: [id], onDelete: Cascade)
  part        Part        @relation(fields: [partId], references: [id])

  @@index([tenantId])
  @@index([billId])
  @@map("stock_bill_items")
}

model StockMovement {
  id            String   @id @default(cuid())
  tenantId      String
  partId        String
  warehouseId   String
  movementType  String   // in, out, adjust
  quantity       Decimal  @db.Decimal(12, 2)
  balanceAfter  Decimal  @db.Decimal(12, 2)
  billId        String?
  billItemId    String?
  relatedType   String?
  relatedId     String?
  operatorId    String
  remark        String?
  createdAt     DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  part      Part      @relation(fields: [partId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  bill      StockBill? @relation(fields: [billId], references: [id])

  @@index([tenantId])
  @@index([partId])
  @@index([warehouseId])
  @@index([createdAt])
  @@map("stock_movements")
}

// ==================== Sprint 3: 结算与会员 ====================

model Settlement {
  id              String   @id @default(cuid())
  tenantId        String
  shopId          String
  settleNo        String   // 结算单号
  workOrderId     String
  totalAmount     Decimal  @db.Decimal(12, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(12, 2)
  payableAmount   Decimal  @db.Decimal(12, 2)
  paidAmount      Decimal  @default(0) @db.Decimal(12, 2)
  debtAmount      Decimal  @default(0) @db.Decimal(12, 2)
  status          String   @default("settled") // pending_payment, settled, refunded, partially_refunded
  remark          String?
  operatorId      String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  payments  Payment[]

  @@unique([tenantId, settleNo])
  @@index([tenantId])
  @@index([tenantId, workOrderId])
  @@map("settlements")
}

model Payment {
  id            String   @id @default(cuid())
  tenantId      String
  settlementId  String
  payMethod     String   // cash, wechat, alipay, card, stored_value, package_card
  amount        Decimal  @db.Decimal(12, 2)
  referenceNo   String?  // 外部流水号
  cardId        String?  // 储值卡/套餐卡 ID
  remark        String?
  status        String   @default("paid")   // pending, paid, refunding, refunded, partially_refunded, failed
  transactionId String?  // 第三方支付平台交易号
  callbackData  Json?    // 回调通知原始数据
  refundAmount  Decimal  @default(0) @db.Decimal(12, 2) // 已退款金额
  paidAt        DateTime? // 实际支付时间（回调确认时间）
  expiredAt     DateTime? // 支付超时时间（默认下单后 15 分钟）
  createdAt     DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  settlement Settlement @relation(fields: [settlementId], references: [id])
  refunds    PaymentRefund[]

  @@index([tenantId])
  @@index([settlementId])
  @@index([transactionId])
  @@map("payments")
}

model PaymentRefund {
  id              String   @id @default(cuid())
  tenantId        String
  paymentId       String
  refundNo        String   // 平台退款单号
  outRefundNo     String?  // 第三方退款单号
  amount          Decimal  @db.Decimal(12, 2)
  reason          String?
  status          String   @default("pending") // pending, success, failed
  callbackData    Json?    // 退款回调原始数据
  operatorId      String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([tenantId])
  @@index([paymentId])
  @@index([refundNo])
  @@map("payment_refunds")
}

model StoredValueCard {
  id              String   @id @default(cuid())
  tenantId        String
  cardNo          String   // 卡号
  customerId      String
  balance         Decimal  @default(0) @db.Decimal(12, 2) // 总余额
  principalBalance Decimal @default(0) @db.Decimal(12, 2) // 本金余额
  giftBalance     Decimal  @default(0) @db.Decimal(12, 2) // 赠送余额
  status          String   @default("active") // active, frozen, cancelled
  remark          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  transactions StoredValueTransaction[]

  @@unique([tenantId, cardNo])
  @@index([tenantId])
  @@index([tenantId, customerId])
  @@map("stored_value_cards")
}

model StoredValueTransaction {
  id          String   @id @default(cuid())
  tenantId    String
  cardId      String
  type        String   // recharge, consume, refund, gift, adjust
  amount      Decimal  @db.Decimal(12, 2) // 正数加、负数减
  principal   Decimal  @default(0) @db.Decimal(12, 2) // 本金变动
  gift        Decimal  @default(0) @db.Decimal(12, 2) // 赠送变动
  balanceAfter Decimal @db.Decimal(12, 2)
  relatedType String?  // settlement, etc
  relatedId   String?
  operatorId  String
  remark      String?
  createdAt   DateTime @default(now())

  tenant Tenant           @relation(fields: [tenantId], references: [id])
  card   StoredValueCard  @relation(fields: [cardId], references: [id])

  @@index([tenantId])
  @@index([cardId])
  @@index([createdAt])
  @@map("stored_value_transactions")
}

model PackageCard {
  id          String   @id @default(cuid())
  tenantId    String
  cardNo      String   // 卡号
  customerId  String
  vehicleId   String?  // 适用车辆
  shopIds     String?  // 适用门店 JSON
  templateId  String?  // 套餐模板
  name        String
  startAt     DateTime
  endAt       DateTime
  status      String   @default("active") // active, expired, cancelled
  remark      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  items       PackageCardItem[]
  transactions PackageCardTransaction[]

  @@unique([tenantId, cardNo])
  @@index([tenantId])
  @@index([tenantId, customerId])
  @@map("package_cards")
}

model PackageCardItem {
  id          String   @id @default(cuid())
  tenantId    String
  cardId      String
  serviceItemId String
  totalQty    Decimal  @db.Decimal(10, 2) // 总次数
  remainQty   Decimal  @db.Decimal(10, 2) // 剩余次数
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  card        PackageCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([cardId])
  @@map("package_card_items")
}

model PackageCardTransaction {
  id          String   @id @default(cuid())
  tenantId    String
  cardId      String
  itemId      String
  type        String   // consume, refund, adjust
  quantity    Decimal  @db.Decimal(10, 2)
  remainAfter Decimal  @db.Decimal(10, 2)
  relatedType String?  // work_order
  relatedId   String?
  operatorId  String
  remark      String?
  createdAt   DateTime @default(now())

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  card   PackageCard     @relation(fields: [cardId], references: [id])

  @@index([tenantId])
  @@index([cardId])
  @@index([createdAt])
  @@map("package_card_transactions")
}

model Sequence {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  date      String
  value     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key, date])
  @@map("sequences")
}

model Notification {
  id          String   @id @default(cuid())
  tenantId    String
  shopId      String?
  channel     String   // sms, internal, wechat_mp
  scene       String   // work_order_completed, renewal_reminder, ...
  recipient   String
  content     String
  status      String   @default("pending") // pending, sent, failed, skipped
  failReason  String?
  relatedType String?
  relatedId   String?
  sentAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([tenantId, scene])
  @@index([relatedType, relatedId])
  @@map("notifications")
}

// ==================== 车主微信小程序 ====================

model CustomerWxBinding {
  id         String   @id @default(cuid())
  tenantId   String
  customerId String
  openid     String
  unionid    String?
  createdAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([tenantId, openid])
  @@index([customerId])
  @@index([openid])
  @@map("customer_wx_bindings")
}

// ==================== 经营提醒 ====================

model Reminder {
  id          String    @id @default(cuid())
  tenantId    String
  shopId      String?
  type        String    // maintenance_due, card_expiring, card_low_balance, customer_churn
  customerId  String
  vehicleId   String?
  relatedId   String?   // 套餐卡id 等
  content     String    // 提醒文案
  dueDate     DateTime  // 提醒归属日期
  status      String    @default("pending") // pending, done, ignored
  handledBy   String?
  handledAt   DateTime?
  remark      String?   // 回访结果备注
  createdAt   DateTime  @default(now())

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  customer    Customer  @relation(fields: [customerId], references: [id])

  @@index([tenantId, type, customerId, vehicleId, relatedId, dueDate])
  @@index([tenantId, shopId, status, dueDate])
  @@map("reminders")
}

// ==================== 营销工具 ====================

model Coupon {
  id              String   @id @default(cuid())
  tenantId        String
  name            String   // 优惠券名称
  type            String   // full_reduction(满减), discount(折扣)
  discountValue   Decimal  @db.Decimal(12, 2) // 满减: 减免金额; 折扣: 折扣率(如 0.85 = 85折)
  conditionAmount Decimal  @default(0) @db.Decimal(12, 2) // 满足条件金额(满减门槛，折扣时为0)
  validDays       Int      @default(30) // 领取后有效天数
  totalQuantity   Int      @default(0) // 总发行量(0=不限)
  issuedQuantity  Int      @default(0) // 已发放数量
  usedQuantity    Int      @default(0) // 已使用数量
  status          String   @default("active") // active, inactive
  remark          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  claims   CouponClaim[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("coupons")
}

model CouponClaim {
  id          String   @id @default(cuid())
  tenantId    String
  couponId    String
  customerId  String
  status      String   @default("unused") // unused, used, expired
  usedAt      DateTime?
  expiredAt   DateTime
  createdAt   DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  coupon   Coupon   @relation(fields: [couponId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([tenantId])
  @@index([couponId])
  @@index([customerId])
  @@index([tenantId, customerId, status])
  @@map("coupon_claims")
}
