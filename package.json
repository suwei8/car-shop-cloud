{
  "name": "car-shop-cloud",
  "version": "0.1.0",
  "private": true,
  "description": "车店云管家 - SaaS 多商户汽服门店管理系统",
  "scripts": {
    "dev": "pnpm --filter @car/api run start:dev & pnpm --filter @car/web run dev",
    "dev:api": "pnpm --filter @car/api run start:dev",
    "dev:web": "pnpm --filter @car/web run dev",
    "build": "pnpm --filter @car/api run build && pnpm --filter @car/web run build",
    "build:api": "pnpm --filter @car/api run build",
    "build:web": "pnpm --filter @car/web run build",
    "lint": "pnpm -r run lint",
    "db:migrate": "pnpm --filter @car/api run prisma:migrate",
    "db:seed": "pnpm --filter @car/api run prisma:seed",
    "db:studio": "pnpm --filter @car/api run prisma:studio",
    "audit:tenant-scope": "pnpm --filter @car/api run audit:tenant-scope",
    "smoke:gray": "pnpm --filter @car/api run smoke:gray",
    "seed:gray": "pnpm --filter @car/api run seed:gray",
    "audit:login-phones": "pnpm --filter @car/api run audit:login-phones",
    "audit:active-uniques": "pnpm --filter @car/api run audit:active-uniques",
    "check:gray-ready": "bash scripts/check-gray-ready.sh",
    "smoke:gray:check": "SMOKE_COMPILE_ONLY=1 pnpm --filter @car/api run smoke:gray"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "@nestjs/core"
    ]
  },
  "devDependencies": {
    "puppeteer": "^25.1.0"
  }
}
