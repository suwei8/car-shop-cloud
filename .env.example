# Database
POSTGRES_USER=car_admin
POSTGRES_PASSWORD=请设置强密码_至少16位
DATABASE_URL=postgresql://car_admin:请设置强密码_至少16位@localhost:5432/car_shop?schema=public

# Redis
REDIS_PASSWORD=请设置强密码_至少16位
REDIS_URL=redis://:请设置强密码_至少16位@localhost:6379
# API Redis (for sms-code rate limiting)
API_REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=请设置至少32位随机字符串
JWT_ACCESS_TOKEN_TTL=2h
JWT_REFRESH_TOKEN_TTL=7d

# MinIO / S3
MINIO_ROOT_USER=car_minio_admin
MINIO_ROOT_PASSWORD=请设置强密码_至少16位
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=car_minio_admin
S3_SECRET_KEY=请设置强密码_至少16位
S3_BUCKET=car-shop
S3_REGION=us-east-1

# App
API_PORT=3000
API_HOST=127.0.0.1
WEB_PORT=5173
# CORS whitelist — comma-separated origins. Legacy CORS_ORIGIN also accepted.
CORS_ORIGINS=http://127.0.0.1:5173

# Subscription Lifecycle
TRIAL_DAYS=30
GRACE_DAYS=7

# SMS (Notification)
SMS_PROVIDER=mock
# ALIYUN_SMS_ACCESS_KEY_ID=your_access_key_id
# ALIYUN_SMS_ACCESS_KEY_SECRET=your_access_key_secret
# ALIYUN_SMS_SIGN_NAME=your_sign_name

# 微信小程序 (Wechat MP)
# WX_MINI_APPID=wx_your_appid
# WX_MINI_SECRET=wx_your_secret

# ===== 支付网关配置 =====
# 支付方式：wechat, alipay, mock（默认 mock）
PAYMENT_PROVIDER=mock

# 微信支付 V2
# WECHAT_PAY_APPID=
# WECHAT_PAY_MCHID=
# WECHAT_PAY_APIV2_KEY=
# WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/payment-callbacks/wechat
# WECHAT_PAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem   # 退款双向 TLS 用
# WECHAT_PAY_CERT_PATH=./certs/apiclient_cert.pem         # 退款双向 TLS 用

# 支付宝
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
# ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment-callbacks/alipay

# Backup (optional, used by scripts/backup/pg-backup.sh)
# BACKUP_LOCAL_DIR=/var/backups/carshop
# BACKUP_RETENTION_DAYS=14
# BACKUP_S3_BUCKET=car-shop
# BACKUP_S3_ENDPOINT=http://localhost:9000
# BACKUP_S3_ACCESS_KEY=car_minio_admin
# BACKUP_S3_SECRET_KEY=请设置强密码_至少16位
# BACKUP_S3_REGION=us-east-1
# BACKUP_ALERT_WEBHOOK=
# PG_CONTAINER=car-postgres
