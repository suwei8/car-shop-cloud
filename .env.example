# Database
POSTGRES_USER=car_admin
POSTGRES_PASSWORD=请设置强密码_至少16位
DATABASE_URL=postgresql://car_admin:请设置强密码_至少16位@localhost:5432/car_shop?schema=public

# Redis
REDIS_PASSWORD=请设置强密码_至少16位
REDIS_URL=redis://:请设置强密码_至少16位@localhost:6379

# JWT
JWT_SECRET=请设置至少32位随机字符串
JWT_ACCESS_TOKEN_TTL=2h
JWT_REFRESH_TOKEN_TTL=7d

# MinIO / S3
MINIO_ROOT_USER=car_minio_admin
MINIO_ROOT_PASSWORD=请设置强密码_至少16位
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=car_minio_admin
S3_SECRET_KEY=请设置强密码_至少16位
S3_BUCKET=car-shop
S3_REGION=us-east-1

# App
API_PORT=3000
API_HOST=127.0.0.1
WEB_PORT=5173
CORS_ORIGIN=http://127.0.0.1:5173

# Backup (optional, used by scripts/backup/pg-backup.sh)
# BACKUP_LOCAL_DIR=/var/backups/carshop
# BACKUP_RETENTION_DAYS=14
# BACKUP_S3_BUCKET=car-shop
# BACKUP_S3_ENDPOINT=http://localhost:9000
# BACKUP_S3_ACCESS_KEY=car_minio_admin
# BACKUP_S3_SECRET_KEY=请设置强密码_至少16位
# BACKUP_S3_REGION=us-east-1
# BACKUP_ALERT_WEBHOOK=
# PG_CONTAINER=car-postgres
